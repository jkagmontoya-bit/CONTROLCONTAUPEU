# Firebase Configuration for "control-de-actividades-conta"
# Fill in your Firebase project credentials from the Firebase Console:
# https://console.firebase.google.com/project/control-de-actividades-conta/settings/general

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=control-de-actividades-conta.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=control-de-actividades-conta
VITE_FIREBASE_STORAGE_BUCKET=control-de-actividades-conta.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id-here
VITE_FIREBASE_APP_ID=your-app-id-here

# To find these values:
# 1. Go to Firebase Console → Project Settings → General
# 2. Under "Your apps", select the web app (or create one)
# 3. Copy the firebaseConfig values from the SDK setup snippet
